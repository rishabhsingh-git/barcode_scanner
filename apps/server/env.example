# ── OpenAI Configuration ─────────────────────────────────────────────────
# Required: Your OpenAI API key
OPENAI_API_KEY=sk-your-api-key-here

# Model to use for barcode reading (gpt-4o-mini is cheapest with vision)
OPENAI_MODEL=gpt-4o-mini

# Max concurrent requests to OpenAI (semaphore limit)
OPENAI_MAX_CONCURRENT=5

# Requests per minute cap (sliding window)
OPENAI_RPM_LIMIT=50

# Max retries on 429 / 5xx errors (exponential backoff)
OPENAI_MAX_RETRIES=3

# Images per chunk for batch processing
OPENAI_CHUNK_SIZE=10

# ── Redis Configuration ─────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Worker Configuration ────────────────────────────────────────────────
# BullMQ worker concurrency (auto-capped to 2x OpenAI concurrency)
MAX_WORKER_CONCURRENCY=10

# ── Storage ──────────────────────────────────────────────────────────────
# Base upload directory (default: ./storage)
UPLOAD_PATH=./storage

# ── Google Cloud Vision API (Optional Fallback) ──────────────────────────
# Path to Google Cloud service account JSON key file
# Download from: https://console.cloud.google.com/iam-admin/serviceaccounts
# Free tier: 1000 images/month, then ~$1.50 per 1000 images
GOOGLE_APPLICATION_CREDENTIALS=./vision-key.json

